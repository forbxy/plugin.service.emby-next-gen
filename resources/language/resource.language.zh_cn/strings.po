msgstr "本地模式（直接路径访问）"

msgctxt "#33039"
msgid "Enable music library?"
msgstr "启用音乐媒体库？"

msgctxt "#33042"
msgid "Running the caching process may take some time. Continue anyway?"
msgstr "运行缓存进程可能需要一些时间，是否要继续？"

